# The URL of the API server
API_URL='http://localhost:4000'

# The username and token for the Twitch bot. You can get the token from https://twitchtokengenerator.com/
BOT_USERNAME='username'
BOT_TOKEN='oauth:your_token_here'

# The URL and API key for your Jellyfin server. You can get the API key from the Jellyfin dashboard under "API Keys".
JELLYFIN_URL='http://localhost:8096'
JELLYFIN_API_KEY='your_jellyfin_api_key_here'